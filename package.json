{
  "name": "steelman",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "test": "jest --forceExit"
  },
  "jest": {
    "preset": "react-native",
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|expo|@expo|@react-navigation|react-native-gesture-handler|react-native-safe-area-context|react-native-screens|expo-status-bar|expo-haptics|expo-linear-gradient|@react-native-async-storage)/)"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleFileExtensions": [
      "js",
      "jsx",
      "json"
    ]
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/stack": "^7.8.4",
    "expo": "~55.0.4",
    "expo-haptics": "^55.0.8",
    "expo-linear-gradient": "^55.0.8",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "^19.2.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "react-native-web": "^0.21.2"
  },
  "private": true,
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.2.0",
    "babel-preset-expo": "^55.0.10",
    "jest": "^30.2.0",
    "react-test-renderer": "^19.2.0"
  }
}
